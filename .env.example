# PostHog public project key (safe to expose to the browser)
VITE_POSTHOG_KEY=phc_your_project_key
# Optional: use https://eu.i.posthog.com for an EU-hosted PostHog project
VITE_POSTHOG_HOST=https://us.i.posthog.com
VITE_SENTRY_DSN=
SENTRY_DSN=

# OpenAI server-side key. Never expose this with a VITE_ prefix.
OPENAI_API_KEY=your_openai_api_key
